            }
          ]
        },
        {
          "name": "Update FCM Token",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{doctorToken}}", "type": "text" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fcm_token\": \"dGhpcyBpcyBhbiBleGFtcGxlIGZjbSB0b2tlbiBmcm9tIG1vYmlsZSBhcHA=\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/doctor/fcm-token",
              "host": ["{{baseUrl}}"],
