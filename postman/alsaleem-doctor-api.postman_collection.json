              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"id\": 1,\n  \"name\": \"Dr. Smith\",\n  \"username\": \"drsmith\",\n  \"bio\": \"Updated bio from mobile app.\",\n  \"profile_picture_url\": null\n}"
            }
