{
  "info": {
    "name": "Alsaleem Doctor API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Doctor-facing API endpoints for mobile app integration. Run Auth > Doctor Login first to save doctorToken."
  },
  "item": [
    {
      "name": "Public",
      "item": [
        {
          "name": "Sliders",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/sliders",
              "host": ["{{baseUrl}}"],
              "path": ["api", "sliders"]
            },
            "description": "Public home sliders (max 3)."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "_postman_previewlanguage": "json",
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "[\n  {\n    \"id\": 1,\n    \"title\": \"Welcome\",\n    \"image_url\": \"http://127.0.0.1:8001/storage/sliders/slide1.jpg\",\n    \"position\": 0,\n    \"url\": \"https://example.com\"\n  }\n]"
            }
          ]
        },
        {
          "name": "Lab Tests",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/lab-tests",
              "host": ["{{baseUrl}}"],
              "path": ["api", "lab-tests"]
            },
            "description": "Public lab test catalog (unauthenticated)."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "_postman_previewlanguage": "json",
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "[\n  {\n    \"id\": 1,\n    \"name\": \"CBC\",\n    \"description\": \"Complete blood count\"\n  }\n]"
            }
          ]
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Doctor Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"drsmith\",\n  \"password\": \"password\",\n  \"device_name\": \"Postman\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/doctor/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "doctor", "login"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  try {",
                  "    var json = pm.response.json();",
                  "    if (json.token) {",
                  "      pm.collectionVariables.set('doctorToken', json.token);",
                  "      pm.test('Saved doctorToken', function () { pm.expect(json.token).to.be.a('string'); });",
                  "    }",
                  "  } catch (e) { /* ignore */ }",
                  "}"
                ]
              }
            }
          ],
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "_postman_previewlanguage": "json",
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"token\": \"abc123def456ghi789jkl012mno345pqr678stu901vwx234yzab567cde890fgh\"\n}"
            },
            {
              "name": "422 Invalid credentials",
              "status": "Unprocessable Entity",
              "code": 422,
              "_postman_previewlanguage": "json",
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"message\": \"Invalid credentials\"\n}"
            }
          ]
        },
        {
          "name": "Doctor Logout",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{doctorToken}}", "type": "text" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/doctor/logout",
              "host": ["{{baseUrl}}"],
              "path": ["api", "doctor", "logout"]
            },
            "description": "Revokes the current device token only."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "_postman_previewlanguage": "json",
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"ok\": true\n}"
            }
          ]
        }
      ]
    },
